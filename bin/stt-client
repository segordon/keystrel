#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"

stt_env_file="${STT_ENV_FILE:-$repo_root/venv/env.sh}"
stt_client_py="${STT_CLIENT_PY:-$repo_root/lib/stt_client.py}"

if [[ ! -f "$stt_env_file" ]]; then
  printf '[stt-client] missing env file: %s\n' "$stt_env_file" >&2
  exit 2
fi

if [[ ! -f "$stt_client_py" ]]; then
  printf '[stt-client] missing client script: %s\n' "$stt_client_py" >&2
  exit 3
fi

source "$stt_env_file"
exec python "$stt_client_py" "$@"
