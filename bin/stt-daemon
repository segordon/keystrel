#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"

stt_env_file="${STT_ENV_FILE:-$repo_root/venv/env.sh}"
stt_daemon_py="${STT_DAEMON_PY:-$repo_root/lib/stt_daemon.py}"

if [[ ! -f "$stt_env_file" ]]; then
  printf '[stt-daemon] missing env file: %s\n' "$stt_env_file" >&2
  exit 2
fi

if [[ ! -f "$stt_daemon_py" ]]; then
  printf '[stt-daemon] missing daemon script: %s\n' "$stt_daemon_py" >&2
  exit 3
fi

source "$stt_env_file"
exec python "$stt_daemon_py" "$@"
